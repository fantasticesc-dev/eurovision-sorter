<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Eurovision 2026 - Bias Sorter</title>
<link href="https://fonts.googleapis.com/css2?family=Singing+Sans:wght@400;700&display=swap" rel="stylesheet">
<style>
body{
  font-family:'Singing Sans', Arial, sans-serif;
  background: linear-gradient(135deg,#0f172a,#3b1053);
  color:white; text-align:center; margin:0; padding:20px; overflow-x:hidden;
}
.container{ max-width:600px; margin:auto; }
button{
  border:none; padding:15px; font-size:18px;
  border-radius:12px; margin:15px 0; cursor:pointer;
  font-family:'Singing Sans', Arial, sans-serif;
  transition: transform 0.2s;
}
button:hover{ transform: scale(1.05); }
.choice{
  padding:30px; margin:20px 0; border-radius:20px;
  font-size:24px; font-weight:700; cursor:pointer;
  background: linear-gradient(45deg,#ff4b4b,#8b0000);
  box-shadow:0 0 15px rgba(255,0,0,0.6),0 8px 20px rgba(0,0,0,0.5);
  transition: transform 0.3s, opacity 0.3s;
  opacity:1; position: relative;
}
.choice.exit{ transform: scale(0.8); opacity:0; }
.choice:hover{ transform: scale(1.05); box-shadow:0 0 25px rgba(255,0,0,0.8);}
.progress-bar-container{
  width:100%; background:#a7f0a7; border-radius:10px; height:20px; margin:10px 0; overflow:hidden;
}
.progress-bar{
  height:100%; width:0%;
  background: linear-gradient(90deg,#22c55e,#06b6d4);
  transition:width 0.2s;
}
.result{
  background: linear-gradient(45deg,#ff4b4b,#8b0000);
  color:white; padding:25px; border-radius:20px;
  margin-top:20px; text-align:left; font-size:18px;
  box-shadow:0 8px 20px rgba(0,0,0,0.5);
  overflow:hidden;
}
.result ol{ padding-left:20px; margin:10px 0; }
.result li{
  opacity:0; transform: translateY(50px);
  transition: all 0.5s ease;
  padding:5px 0; border-radius:10px; margin-bottom:3px;
}
.result li:hover{ transform: scale(1.05); text-shadow: 0 0 10px #fff; }

button.restart-btn,
button.back-menu-btn,
button.save-btn,
a.linktree-btn {
  background: linear-gradient(45deg,#ff4b4b,#c70000); /* red gradient */
  color: white;
  border: 2px solid black;
  padding: 12px;
  font-size: 16px;
  border-radius: 12px;
  margin-top: 10px;
  width: 90%;
  text-align: left;
  display: block;
  text-decoration: none;
  box-shadow: 0 4px 8px rgba(0,0,0,0.5);
  transition: transform 0.2s, box-shadow 0.2s;
}
button.restart-btn:hover,
button.back-menu-btn:hover,
button.save-btn:hover,
a.linktree-btn:hover {
  transform: scale(1.03);
  box-shadow: 0 6px 12px rgba(0,0,0,0.7);
}

.confetti-piece{
  position:fixed; width:10px; height:10px;
  top:0; left:50%; opacity:0.8; transform:rotate(45deg);
  pointer-events:none; z-index:9999; animation:confetti-fall 3s linear forwards;
}
@keyframes confetti-fall{
  0%{ transform:translateY(0) rotate(45deg); opacity:1; }
  100%{ transform:translateY(100vh) rotate(720deg); opacity:0; }
}
</style>
</head>
<body>
<div class="container">
<h1>Eurovision 2026 - Bias Sorter</h1>

<div id="menu">
<p>Select a sorter:</p>
<button data-sorter="overall">OVERALL RANKING</button>
<button data-sorter="sf1">SEMIFINAL 1</button>
<button data-sorter="sf2">SEMIFINAL 2</button>
</div>

<div id="duel" style="display:none">
<h2>Choose one</h2>
<div id="choices"></div>
<div class="progress-bar-container">
  <div id="progressBar" class="progress-bar"></div>
</div>
<button class="restart-btn" onclick="restartSorter()">Restart Sorter</button>
<button class="undo-btn" id="undoBtn">Undo Last Choice</button>
</div>

<div id="results"></div>

<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script>
const lineups={
overall:["🇭🇷 LELEK - Andromeda","🇫🇮 Linda Lampenius & Pete Parkkonen - Liekinheitin","🇬🇪 Bzikebi - On Repeat","🇬🇷 Akylas - Ferto","🇲🇩 Satoshi - Viva, Moldova!","🇵🇹 Bandidos do Cante - Rosa","🇸🇪 Felicia - My System","🇧🇪 Essyla - Dancing On The Ice","🇪🇪 Vanilla Ninja - Too Epic To Be True","🇮🇱 Noam Bettan - Michelle","🇱🇹 Lion Ceccah - Sólo quiero más","🇲🇪 Tamara Živković - Nova Zora","🇵🇱 Alicja - Pray","🇸🇲 Senhit & Boy George - Superstar","🇷🇸 Lavina - Kraj Mene","🇦🇲 ??? - ???","🇦🇿 JIVA - Just Go","🇧🇬 Dara - Bangaranga","🇨🇿 Daniel Žižka - Crossroads","🇱🇺 Eva Marija - Mother Nature","🇷🇴 Alexandera Capitanescu - Choke Me","🇨🇭 Veronica Fusaro - ???","🇦🇱 Alis - Nân","🇦🇺 Delta Goodrem - Eclipse","🇨🇾 Antigoni - Jalla","🇩🇰 Søren Torpegaard Lund - Før Vi Går Hjem","🇱🇻 Atvara - Ēnā","🇲🇹 Aidan - Bella","🇳🇴 Jonas Lovv - Ya Ya Ya","🇺🇦 Leléka - Ridnym","🇦🇹 Cosmó - Tanzschein","🇫🇷 Monroe - Regarde!","🇩🇪 Sarah Engels - Fire","🇮🇹 Sal da Vinci - Per Sempre Sì","🇬🇧 Look Mum No Computer - Eins, Zwei, Drei"],
sf1:["🇭🇷 LELEK - Andromeda","🇫🇮 Linda Lampenius & Pete Parkkonen - Liekinheitin","🇬🇪 Bzikebi - On Repeat","🇬🇷 Akylas - Ferto","🇲🇩 Satoshi - Viva, Moldova!","🇵🇹 Bandidos do Cante - Rosa","🇸🇪 Felicia - My System","🇧🇪 Essyla - Dancing On The Ice","🇪🇪 Vanilla Ninja - Too Epic To Be True","🇮🇱 Noam Bettan - Michelle","🇱🇹 Lion Ceccah - Sólo quiero más","🇲🇪 Tamara Živković - Nova Zora","🇵🇱 Alicja - Pray","🇸🇲 Senhit & Boy George - Superstar","🇷🇸 Lavina - Kraj Mene"],
sf2:["🇦🇲 ??? - ???","🇦🇿 JIVA - Just Go","🇧🇬 Dara - Bangaranga","🇨🇿 Daniel Žižka - Crossroads","🇱🇺 Eva Marija - Mother Nature","🇷🇴 Alexandera Capitanescu - Choke Me","🇨🇭 Veronica Fusaro - ???","🇦🇱 Alis - Nân","🇦🇺 Delta Goodrem - Eclipse","🇨🇾 Antigoni - Jalla","🇩🇰 Søren Torpegaard Lund - Før Vi Går Hjem","🇱🇻 Atvara - Ēnā","🇲🇹 Aidan - Bella","🇳🇴 Jonas Lovv - Ya Ya Ya","🇺🇦 Leléka - Ridnym"]
};

let currentList=[], duelHistory=[], currentResolve=null, currentKey="";

document.querySelectorAll('#menu button').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    currentKey=btn.dataset.sorter;
    startSorter(currentKey);
  });
});
document.getElementById('undoBtn').addEventListener('click', undoLast);

function startSorter(key){
  currentList = lineups[key].slice();
  duelHistory=[];
  document.getElementById("menu").style.display="none";
  document.getElementById("results").innerHTML="";
  document.getElementById("duel").style.display="block";
  mergeSort(currentList).then(r=>showResults(r));
}

async function mergeSort(arr){
  if(arr.length<=1) return arr;
  let mid=Math.floor(arr.length/2);
  let left=await mergeSort(arr.slice(0,mid));
  let right=await mergeSort(arr.slice(mid));
  return await merge(left,right);
}

async function merge(left,right){
  let result=[];
  while(left.length && right.length){
    let winner=await duel(left[0], right[0]);
    if(winner===left[0]) result.push(left.shift());
    else result.push(right.shift());
  }
  return result.concat(left,right);
}

function duel(a,b){
  return new Promise(resolve=>{
    currentResolve=resolve;
    const choicesDiv=document.getElementById("choices");
    choicesDiv.innerHTML="";
    const leftBtn=document.createElement('div');
    leftBtn.className="choice"; leftBtn.textContent=a; choicesDiv.appendChild(leftBtn);
    const rightBtn=document.createElement('div');
    rightBtn.className="choice"; rightBtn.textContent=b; choicesDiv.appendChild(rightBtn);

    leftBtn.style.opacity=0; rightBtn.style.opacity=0;
    requestAnimationFrame(()=>{ leftBtn.style.opacity=1; rightBtn.style.opacity=1; });

    leftBtn.addEventListener('click', ()=>animateChoice(leftBtn,rightBtn,a,[a,b]));
    rightBtn.addEventListener('click', ()=>animateChoice(rightBtn,leftBtn,b,[a,b]));
  });
}

function animateChoice(chosen,other,choice,pair){
  chosen.classList.add('exit'); other.classList.add('exit');
  setTimeout(()=>resolveChoice(choice,pair),300);
}

function resolveChoice(choice,pair){
  if(currentResolve){
    duelHistory.push({left:pair[0], right:pair[1], winner:choice});
    currentResolve(choice);
    currentResolve=null;
    updateProgress();
  }
}

function updateProgress(){
  let totalComparisons = Math.ceil(currentList.length * Math.log2(currentList.length));
  let percent = Math.round((duelHistory.length / totalComparisons) * 100);
  document.getElementById("progressBar").style.width = percent + "%";
}

function undoLast(){
  if(duelHistory.length===0) return;
  duelHistory.pop();
  startSorter(currentKey);
}

function showResults(r){
  document.getElementById("duel").style.display="none";
  document.getElementById("results").innerHTML="<div class='result'><h2>Final Ranking</h2><ol id='rankingList'></ol><button class='back-menu-btn' onclick='backToMenu()'>Back to Main Menu</button><button class='save-btn' onclick='saveRanking()'>Save as Image</button><a href='https://youtube.com/@fantasticesc?si=jNPew400WwNNxfz5' target='_blank' class='linktree-btn'>Visit My YouTube</a></div>";

  const rankingList = document.getElementById('rankingList');
  r.forEach((x)=>{  // no manual numbers
    const li = document.createElement('li');
    li.textContent = x;
    rankingList.appendChild(li);
  });

  const lis = rankingList.querySelectorAll('li');
  lis.forEach((li,i)=>setTimeout(()=>{
    li.style.opacity=1;
    li.style.transform='translateY(0)';
  }, i*150));

  for(let i=0;i<100;i++){
    const c = document.createElement('div');
    c.className='confetti-piece';
    c.style.left=Math.random()*100+'%';
    c.style.background=`hsl(${Math.random()*360},100%,50%)`;
    c.style.animationDuration=(2+Math.random()*2)+'s';
    document.body.appendChild(c);
    setTimeout(()=>c.remove(),4000);
  }

  document.getElementById("progressBar").style.width="100%";
}

function restartSorter(){
  startSorter(currentKey);
}

function backToMenu(){
  document.getElementById("results").innerHTML="";
  document.getElementById("menu").style.display="block";
  document.getElementById("duel").style.display="none";
  document.getElementById("progressBar").style.width="0%";
}

function saveRanking(){
  const resultsDiv = document.querySelector('.result');
  html2canvas(resultsDiv).then(canvas=>{
    const link=document.createElement('a');
    link.download="Eurovision2026_Ranking.png";
    link.href=canvas.toDataURL();
    link.click();
  });
}
</script>
</body>
</html>
